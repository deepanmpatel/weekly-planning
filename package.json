{
  "name": "asana-local",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["api", "web"],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm --workspace api run dev",
    "dev:web": "npm --workspace web run dev",
    "seed": "npm --workspace api run seed",
    "build": "npm --workspace api run build && npm --workspace web run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
