# Local dev: point at the Express server running on :3001.
# In production (Vercel), leave this unset — the app auto-uses same-origin "/api".
VITE_API_BASE=http://localhost:3001

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Demo mode — runs the app entirely in the browser with seed data, no backend
# or Supabase needed. Useful for exploring the UI without setup. The
# `npm run dev:demo` script sets this for you; you don't normally edit it here.
# VITE_DEMO_MODE=true
